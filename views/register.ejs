<!DOCTYPE html>
<html lang="en" class="dark">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>nexEnginner — Register</title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Google Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    rel="stylesheet">

  <style>
    body {
      font-family: 'Inter', sans-serif;
      background: #050816;
      overflow-x: hidden;
    }

    .gradient-text {
      background: linear-gradient(90deg, #8b5cf6, #06b6d4, #ec4899);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .glass {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(18px);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .btn-primary {
      background: linear-gradient(135deg, #7c3aed, #06b6d4);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 40px rgba(124, 58, 237, 0.4);
    }

    .blob {
      position: absolute;
      border-radius: 9999px;
      filter: blur(100px);
      opacity: .2;
      z-index: 0;
    }
  </style>

</head>

<body class="min-h-screen flex items-center justify-center px-6 relative text-white">

  <!-- BACKGROUND BLOBS -->

  <div class="blob bg-violet-500 w-[300px] h-[300px] top-0 left-0"></div>

  <div class="blob bg-cyan-500 w-[300px] h-[300px] bottom-0 right-0"></div>

  <!-- REGISTER CARD -->

  <div class="glass relative z-10 w-full max-w-md rounded-[35px] p-8 md:p-10 shadow-2xl">

    <!-- LOGO -->

    <div class="flex flex-col items-center text-center mb-8">

      <img
        src="/logo_new.png"
        alt="Logo"
        class="w-24 h-24 rounded-3xl object-cover shadow-lg mb-5">

      <h1 class="text-4xl font-black">
        nex<span class="gradient-text">Enginner</span>
      </h1>

      <p class="text-white/50 mt-3">
        Create your student account
      </p>

    </div>

 <!-- FORM -->
<% if(message){ %>

    <div style="
        background:#7c3aed;
        color:white;
        padding:15px;
        border-radius:12px;
        margin-bottom:20px;
        text-align:center;
        font-weight:bold;
    ">

        <%= message %>

    </div>

<% } %>
    <form action="/register" method="POST" class="space-y-5">

      <!-- NAME -->

      <div>

        <label class="text-sm text-white/60 mb-2 block">
          Full Name
        </label>

        <div class="relative">

          <i class="bi bi-person absolute left-4 top-1/2 -translate-y-1/2 text-white/40"></i>

          <input
            type="text"
            name="name"
            placeholder="Enter your name"
            required
            class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 outline-none focus:border-violet-500 transition">

        </div>

      </div>

      <!-- EMAIL -->

      <div>

        <label class="text-sm text-white/60 mb-2 block">
          Email Address
        </label>

        <div class="relative">

          <i class="bi bi-envelope absolute left-4 top-1/2 -translate-y-1/2 text-white/40"></i>

          <input
            type="email"
            name="email"
            placeholder="Enter your email"
            required
            class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 outline-none focus:border-cyan-500 transition">

        </div>

      </div>

      <!-- PASSWORD -->

      <div>

        <label class="text-sm text-white/60 mb-2 block">
          Password
        </label>

        <div class="relative">

          <i class="bi bi-lock absolute left-4 top-1/2 -translate-y-1/2 text-white/40"></i>

          <input
            type="password"
            name="password"
            placeholder="Create password"
            required
            class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 outline-none focus:border-pink-500 transition">

        </div>

      </div>

      <!-- BUTTON -->

      <button
        type="submit"
        class="w-full py-4 rounded-2xl btn-primary font-semibold text-lg transition duration-300">

        <i class="bi bi-stars mr-2"></i>

        Create Account

      </button>

    </form>

    <!-- LOGIN -->

    <p class="text-center text-white/50 mt-8">

      Already have an account?

      <a href="/login"
        class="text-violet-400 hover:text-violet-300 font-semibold transition">

        Login

      </a>

    </p>

  </div>

</body>

</html>